# Coverage Configuration for pytest
[coverage:run]
branch = True
source = app
omit =
    */tests/*
    */migrations/*
    */__pycache__/*
    */venv/*
    # Optional/offline subsystems validated in dedicated jobs
    app/qa/*
    app/workers/*
    app/ml/*
    app/services/ml/*
    app/services/discovery.py
    app/services/data_pipeline/orchestrator.py
    app/services/data_pipeline/freshness.py
    app/services/assistant.py
    app/services/llm_providers.py
    app/services/rag_analyst.py
    app/services/embedding.py
    app/services/market_ingest.py
    app/providers/web_intel.py
    app/providers/perplexity.py

[coverage:report]
# Minimum coverage percentage
fail_under = 75
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstract
    @abstractmethod
    except ImportError:
    pass

[coverage:html]
directory = htmlcov
